<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="GlassContainerBase"
           TargetType="Border">
        <Setter Property="Background"
                Value="#1AFFFFFF" />
        <Setter Property="BorderBrush"
                Value="#4DFFFFFF" />
    </Style>

    <Style x:Key="SidebarContainerStyle"
           BasedOn="{StaticResource GlassContainerBase}"
           TargetType="Border">
        <Setter Property="CornerRadius"
                Value="40,15,15,40" />
    </Style>

    <Style x:Key="MainContainerStyle"
           BasedOn="{StaticResource GlassContainerBase}"
           TargetType="Border">
        <Setter Property="CornerRadius"
                Value="15,40,40,15" />
    </Style>
    
    <Style x:Key="BorderContainerStyle"
           TargetType="Border">
        <Setter Property="CornerRadius"
                Value="15,40,40,15" />
        <Setter Property="BorderBrush"
                Value="White" />
        <Setter Property="BorderThickness"
                Value="2" />
    </Style>

    <Style x:Key="BorderSidebarStyle"
           TargetType="Border">
        <Setter Property="CornerRadius"
                Value="40,15,15,40" />
        <Setter Property="BorderBrush"
                Value="White" />
        <Setter Property="BorderThickness"
                Value="2" />
    </Style>
</ResourceDictionary>