<UserControl x:Class="PhatDat_FoodStore.Views.UserControls.Login_UC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:PhatDat_FoodStore.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <!-- Phần DataContext-->
    <UserControl.DataContext>
        <vm:LoginViewModel />
    </UserControl.DataContext>

    <!-- Phần Grid của Form -->
    <Grid Margin="30,40,30,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <TextBlock Text="LOGIN"
                   Grid.ColumnSpan="2"
                   Grid.Row="0"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"
                   Style="{StaticResource TextBlockTitleStyle}">
            <TextBlock.Effect>
                <DropShadowEffect BlurRadius="10"
                                  ShadowDepth="2"
                                  Opacity="0.8" />
            </TextBlock.Effect>
        </TextBlock>

        <!-- Nhập Username-->
        <TextBlock Text="Username:"
                   Grid.Row="1"
                   VerticalAlignment="Center"
                   Style="{StaticResource TextBlockContentStyle}" />
        <TextBox x:Name="txtUsername"
                 Text="{Binding GetUsername}"
                 Grid.Column="1"
                 Grid.Row="1"
                 Style="{StaticResource TextBlockInputStyle}" />

        <!-- Nhập Password-->
        <TextBlock Text="Password:"
                   Grid.Row="2"
                   VerticalAlignment="Center"
                   Style="{StaticResource TextBlockContentStyle}" />
        <PasswordBox x:Name="pwbPassword"
                     Grid.Column="1"
                     Grid.Row="2"
                     Style="{StaticResource TextBlockInputStyle}" />

        <!-- Quên mật khẩu -->
        <Button x:Name="btnForgetPass"
                Content="Quên mật khẩu?"
                Grid.ColumnSpan="2"
                Grid.Row="3"
                Foreground="Snow"
                Cursor="Hand"
                FontFamily="Cascadia Mono">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <TextBlock Text="{TemplateBinding Content}"
                               TextDecorations="Underline"
                               HorizontalAlignment="Right"
                               Margin="0,0,70,0"
                               x:Name="txtFP" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="txtFP"
                                    Property="Foreground"
                                    Value="SkyBlue" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Phần nút Login và Sign In-->
        <StackPanel Grid.Row="4"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center">

            <!-- Nút Login -->
            <Button x:Name="btnLogin"
                    Content="Login"
                    Width="140"
                    Height="45"
                    Background="White"
                    Foreground="#0077B6"
                    Margin="10"
                    FontFamily="Cascadia Mono"
                    FontSize="18"
                    Command="{Binding LoginCommand}"
                    CommandParameter="{Binding ElementName=pwbPassword}"
                    Style="{StaticResource ButtonStyle}" />


            <!-- Nút Sign In-->
            <Button x:Name="btnSignIn"
                    Content="Sign in"
                    Width="140"
                    Height="45"
                    Background="White"
                    Foreground="#0077B6"
                    FontSize="18"
                    FontFamily="Cascadia Mono"
                    Margin="10"
                    Command="{Binding DataContext.SwitchViewCommand, 
                          RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="Register"
                    Style="{StaticResource ButtonStyle}" />


        </StackPanel>

        <!-- Phần Copyright -->
        <TextBlock Text="Copyright 2026 Fenda404"
                   Grid.Row="5"
                   Grid.ColumnSpan="2"
                   HorizontalAlignment="Center"
                   Foreground="#80FFD8BE"
                   FontSize="11"
                   VerticalAlignment="Bottom"
                   FontFamily="Cascadia Mono" />
    </Grid>
</UserControl>
