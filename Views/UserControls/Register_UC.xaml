<UserControl x:Class="PhatDat_FoodStore.Views.UserControls.Register_UC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:PhatDat_FoodStore.ViewModels"
             xmlns:cvts="clr-namespace:PhatDat_FoodStore.Converters"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <UserControl.DataContext>
        <vm:RegisterViewModel />
        
    </UserControl.DataContext>
    
    <UserControl.Resources>

        <cvts:ListParameterConverter x:Key="ListConverter" />

        <!-- Phần riêng của nút back -->
        <SolidColorBrush x:Key="PrimaryColor"
                         Color="WhiteSmoke" />
        <SolidColorBrush x:Key="HoverColor"
                         Color="#26A0DA" />
        <SolidColorBrush x:Key="DisabledColor"
                         Color="#CCCCCC" />

        <ControlTemplate x:Key="BackButtonStyleTemplate"
                         TargetType="Button">
            <Border x:Name="border"
                    Background="Transparent"
                    BorderThickness="0"
                    CornerRadius="5"
                    Padding="8,5">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Path x:Name="arrowIcon"
                          Data="M 8,0 L 0,8 L 8,16"
                          Stroke="{StaticResource PrimaryColor}"
                          StrokeThickness="2.5"
                          StrokeEndLineCap="Round"
                          StrokeStartLineCap="Round"
                          Margin="0,0,8,0"
                          VerticalAlignment="Center" />

                    <ContentPresenter x:Name="txtBack"
                                      Content="Back"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center">
                        <ContentPresenter.Resources>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Foreground"
                                        Value="{StaticResource PrimaryColor}" />
                                <Setter Property="FontSize"
                                        Value="14" />
                                <Setter Property="FontWeight"
                                        Value="SemiBold" />
                                <Setter Property="FontFamily"
                                        Value="Cascadia Mono" />

                            </Style>
                        </ContentPresenter.Resources>
                    </ContentPresenter>
                </StackPanel>
            </Border>

            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter TargetName="arrowIcon"
                            Property="Stroke"
                            Value="{StaticResource HoverColor}" />
                    <Setter Property="Cursor"
                            Value="Hand" />
                </Trigger>


                <Trigger Property="IsEnabled"
                         Value="False">
                    <Setter TargetName="arrowIcon"
                            Property="Stroke"
                            Value="{StaticResource DisabledColor}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </UserControl.Resources>

        <!-- Phần Grid của Form -->
    <Grid Margin="30,40,30,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="*" />
            <RowDefinition Height="80" />
            <RowDefinition Height="*" />
            <RowDefinition Height="70" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <!-- Tiêu đề + nút Back -->
        <Button Template="{StaticResource BackButtonStyleTemplate}"
                Margin="10"
                Grid.Row="0"
                Grid.Column="0"
                Command="{Binding DataContext.SwitchViewCommand, 
                          RelativeSource={RelativeSource AncestorType=Window}}"
                CommandParameter="Login" />

        <TextBlock Text="SIGN IN"
                   Grid.ColumnSpan="2"
                   Grid.Row="0"
                   HorizontalAlignment="Center"
                   Style="{StaticResource TextBlockTitleStyle}">
            <TextBlock.Effect>
                <DropShadowEffect BlurRadius="10"
                                  ShadowDepth="2"
                                  Opacity="0.8" />
            </TextBlock.Effect>
        </TextBlock>

        <!-- Nhập Username-->
        <TextBlock Text="Username:"
                   Grid.Row="1"
                   VerticalAlignment="Center"
                   Style="{StaticResource TextBlockContentStyle}" />
        <TextBox x:Name="txtUsername"
                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                 Grid.Column="1"
                 Grid.Row="1"
                 Style="{StaticResource TextBlockInputStyle}" />

        <!-- Nhập Password-->
        <TextBlock Text="Password:"
                   Grid.Row="2"
                   VerticalAlignment="Center"
                   Style="{StaticResource TextBlockContentStyle}" />
        <StackPanel Grid.Column="1"
                    Grid.Row="2">
            <PasswordBox x:Name="pwbPassword"
                         Style="{StaticResource TextBlockInputStyle}" />
            <TextBlock Text="* Tối thiểu 8 ký tự, bao gồm chữ hoa, số và ký tự đặc biệt"
                       Foreground="Red" />
        </StackPanel>
        <!-- Xác nhận mật khẩu -->
        <TextBlock Text="* Password:"
                   Grid.Row="3"
                   VerticalAlignment="Center"
                   Style="{StaticResource TextBlockContentStyle}" />
        <PasswordBox x:Name="pwbConfirmPass"
                     Grid.Column="1"
                     Grid.Row="3"
                     Style="{StaticResource TextBlockInputStyle}" />


        <!-- Phần nút Login và Sign In-->
        <StackPanel Grid.Row="4"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center">


            <!-- Nút Sign In-->
            <Button x:Name="btnSignIn"
                    Content="Sign in"
                    Command="{Binding RegisterCommand}"
                    Style="{StaticResource ButtonStyle}">
                <Button.CommandParameter>
                    <MultiBinding Converter="{StaticResource ListConverter}">
                        <Binding ElementName="pwbPassword" />
                        <Binding ElementName="pwbConfirmPass" />
                    </MultiBinding>
                </Button.CommandParameter>
            </Button>
        </StackPanel>

        <!-- Phần Copyright -->
        <TextBlock Text="Copyright 2026 Fenda404"
                   Grid.Row="5"
                   Grid.ColumnSpan="2"
                   HorizontalAlignment="Center"
                   Foreground="#80FFD8BE"
                   FontSize="11"
                   VerticalAlignment="Bottom"
                   FontFamily="Cascadia Mono" />
    </Grid>
</UserControl>
