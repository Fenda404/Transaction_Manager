<Window x:Class="PhatDat_FoodStore.Views.MainLoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PhatDat_FoodStore.ViewModels"
        xmlns:uc="clr-namespace:PhatDat_FoodStore.Views.UserControls"
        mc:Ignorable="d"
        Title="Xác thực"
        Height="600"
        Width="800"
        Icon="/Resources/Images/Fenda_logo_2_removed.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent">


    <Window.DataContext>
        <vm:MainLoginViewModel />
    </Window.DataContext>

    <Window.Resources>

        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <uc:Login_UC />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:RegisterViewModel}">
            <uc:Register_UC />
        </DataTemplate>

        <Storyboard x:Key="GlowAnimation">
            <DoubleAnimation Storyboard.TargetName="GlowEffect"
                             Storyboard.TargetProperty="BlurRadius"
                             From="25"
                             To="50"
                             Duration="0:0:2.5"
                             AutoReverse="True"
                             RepeatBehavior="Forever" />
        </Storyboard>

        <PathGeometry x:Key="LoginFrameGeometry">
            <PathFigure StartPoint="20,0"
                        IsClosed="True">
                <QuadraticBezierSegment Point1="300,20"
                                        Point2="580,0" />
                <ArcSegment Point="600,20"
                            Size="20,20"
                            SweepDirection="Clockwise" />
                <LineSegment Point="600,380" />
                <ArcSegment Point="580,400"
                            Size="20,20"
                            SweepDirection="Clockwise" />
                <QuadraticBezierSegment Point1="300,380"
                                        Point2="20,400" />
                <ArcSegment Point="0,380"
                            Size="20,20"
                            SweepDirection="Clockwise" />
                <LineSegment Point="0,20" />
                <ArcSegment Point="20,0"
                            Size="20,20"
                            SweepDirection="Clockwise" />
            </PathFigure>
        </PathGeometry>
    </Window.Resources>


    <!-- Phần Window Trigger (Bộ kích hoạt)-->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource GlowAnimation}" />
        </EventTrigger>
    </Window.Triggers>

    <!-- Phần Grid chính -->
    <Grid>
        <!-- Trình phát Video-->
        <MediaElement x:Name="bgVideo"
                      Source="Resources/Videos/Animation_Pixel_BG.mp4"
                      LoadedBehavior="Play"
                      UnloadedBehavior="Stop"
                      Stretch="UniformToFill"
                      IsMuted="True"
                      RenderOptions.BitmapScalingMode="LowQuality">
            <MediaElement.Effect>
                <BlurEffect Radius="10" />
            </MediaElement.Effect>
        </MediaElement>

        <Rectangle Fill="Black"
                   Opacity="0.2" />

        <Grid VerticalAlignment="Center"
              HorizontalAlignment="Center"
              Width="600"
              Height="400">
            <!-- Grid của phần Path-->
            <Grid>
                <Grid.CacheMode>
                    <BitmapCache EnableClearType="False"
                                 RenderAtScale="1" />
                </Grid.CacheMode>
                <Path Data="{StaticResource LoginFrameGeometry}"
                      Fill="#1AFFFFFF"
                      Stroke="White"
                      StrokeThickness="2.5"
                      Stretch="Fill">
                    <Path.Effect>
                        <DropShadowEffect x:Name="GlowEffect"
                                          Color="White"
                                          BlurRadius="25"
                                          ShadowDepth="0"
                                          Opacity="0.5" />
                    </Path.Effect>
                </Path>

                <ContentControl Content="{Binding CurrentView}" />

            </Grid>

        </Grid>
    </Grid>
</Window>
